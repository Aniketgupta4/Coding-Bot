<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeBot | The AI Coding Revolution</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        const savedTheme = localStorage.getItem('site-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <style>
        :root {
            /* Dark Theme (Premium Matte Look) */
            --bg: #0a0a0a;
            --surface: #141414;
            --text: #ffffff;
            --text-dim: #a1a1aa;
            --primary: #22c55e;
            --primary-glow: rgba(34, 197, 94, 0.15);
            --accent: #3b82f6;
            --border: #27272a;
            --glass: rgba(10, 10, 10, 0.8);
            --scrollbar-thumb: rgba(255, 255, 255, 0.2);
        }

        [data-theme="light"] {
            /* Light Theme */
            --bg: #ffffff;
            --surface: #f4f4f5;
            --text: #09090b;
            --text-dim: #64748b;
            --primary: #16a34a;
            --primary-glow: rgba(22, 163, 74, 0.1);
            --accent: #2563eb;
            --border: #e4e4e7;
            --glass: rgba(255, 255, 255, 0.8);
            --scrollbar-thumb: rgba(0, 0, 0, 0.2);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        /* --- CUSTOM SLEEK SCROLLBAR --- */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        /* --- NAVBAR --- */
        nav {
            position: fixed; top: 0; width: 100%;
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 5%;
            background: var(--glass);
            backdrop-filter: blur(12px);
            z-index: 1000;
            border-bottom: 1px solid var(--border);
        }

        .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 8px; text-decoration: none; }
        
        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text); font-weight: 600; font-size: 0.95rem; opacity: 0.9; transition: 0.3s; }
        .nav-links a:hover { opacity: 1; color: var(--primary); }

        /* Hamburger Menu Icon */
        .mobile-menu-btn {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            background: none;
            border: none;
            z-index: 1100;
        }
        .mobile-menu-btn span { width: 25px; height: 2px; background-color: var(--text); transition: 0.3s; }

        /* Theme Toggle */
        .theme-toggle-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }
        .theme-toggle-btn:hover { border-color: var(--primary); }

        /* --- HERO SECTION --- */
        .hero { padding: 160px 5% 100px; text-align: center; background: radial-gradient(circle at 50% -20%, var(--primary-glow), transparent 50%); }
        .hero h1 { font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 800; letter-spacing: -2px; line-height: 1.1; margin-bottom: 20px; }
        .hero h1 span { color: var(--primary); }
        .hero p { max-width: 650px; margin: 0 auto 40px; font-size: 1.2rem; color: var(--text-dim); line-height: 1.6; }

        .cta-group { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .btn { padding: 14px 32px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.3s; text-decoration: none; border: none; font-size: 1rem; }
        .btn-primary { background: var(--primary); color: #000; box-shadow: 0 10px 25px -5px var(--primary-glow); }
        .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
        .btn:hover { transform: translateY(-3px); filter: brightness(1.1); }

        /* --- FLOATING STATS --- */
        .stats-section { display: flex; justify-content: center; gap: 50px; flex-wrap: wrap; padding: 40px 5%; border-bottom: 1px solid var(--border); }
        .stat-item { text-align: center; }
        .stat-item h2 { font-size: 2.5rem; color: var(--text); margin-bottom: 5px; }
        .stat-item p { color: var(--primary); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }

        /* --- TERMINAL --- */
        .terminal-container { padding: 80px 5%; }
        .terminal { max-width: 900px; margin: 0 auto; background: #000; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.5); }
        .term-head { background: #1a1a1a; padding: 14px 20px; display: flex; gap: 8px; border-bottom: 1px solid #333; }
        .dot { width: 12px; height: 12px; border-radius: 50%; }
        .term-body { padding: 30px; font-family: 'Fira Code', monospace; color: #a1a1aa; font-size: 15px; line-height: 1.8; }

        /* --- FEATURES --- */
        .section { padding: 100px 5%; }
        .section-header { text-align: center; margin-bottom: 60px; }
        .section-header h2 { font-size: 2.5rem; margin-bottom: 15px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; max-width: 1200px; margin: 0 auto; }
        .card { background: var(--surface); padding: 40px; border-radius: 20px; border: 1px solid var(--border); transition: 0.3s; }
        .card:hover { border-color: var(--primary); transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .card h3 { margin-bottom: 15px; font-size: 1.4rem; display: flex; align-items: center; gap: 10px; }
        .card p { color: var(--text-dim); line-height: 1.6; }

        /* --- SLIDER --- */
        .slider-container { background: var(--surface); padding: 30px 0; overflow: hidden; white-space: nowrap; border-top: 1px solid var(--border); }
        .slider { display: inline-block; animation: slide 20s linear infinite; }
        .slider span { font-size: 1.5rem; font-weight: 800; margin: 0 40px; color: var(--text-dim); opacity: 0.4; }
        @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        /* --- TESTIMONIALS --- */
        .testimonials { background: var(--bg); }
        .test-card { font-style: italic; font-size: 1.1rem; border-left: 4px solid var(--primary); padding-left: 20px; }

        /* --- UNIFIED SHARED FOOTER --- */
        footer { padding: 80px 5% 40px; background: var(--surface); border-top: 1px solid var(--border); }
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 60px; max-width: 1200px; margin-left: auto; margin-right: auto; }
        .footer-col h4 { margin-bottom: 20px; font-weight: 700; color: var(--text); font-size: 1.1rem; }
        .footer-col a { display: block; text-decoration: none; color: var(--text-dim); margin-bottom: 12px; font-size: 0.95rem; transition: 0.2s; }
        .footer-col a:hover { color: var(--primary); transform: translateX(3px); }
        .copyright { text-align: center; color: var(--text-dim); font-size: 0.85rem; padding-top: 40px; border-top: 1px solid var(--border); }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .mobile-menu-btn { display: flex; }
            .nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; width: 100%; background: var(--surface); padding: 20px; gap: 20px; border-bottom: 1px solid var(--border); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
            .nav-links.active { display: flex; }
            .nav-links .btn { width: 100%; text-align: center; }
            .theme-toggle-btn { width: 100%; justify-content: center; }
            .hero h1 { font-size: 3.2rem; }
            .footer-grid { grid-template-columns: 1fr 1fr; }
            .footer-grid .footer-col:first-child { grid-column: span 2; }
        }
        @media (max-width: 480px) {
            .footer-grid { grid-template-columns: 1fr; }
            .footer-grid .footer-col:first-child { grid-column: span 1; }
        }
    </style>
</head>
