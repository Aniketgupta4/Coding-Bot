<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeBot | The AI Coding Revolution</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Dark Theme (Re-designed for Premium Matte Look) */
            --bg: #0a0a0a;
            --surface: #141414;
            --text: #ffffff;
            --text-dim: #a1a1aa;
            --primary: #22c55e;
            --primary-glow: rgba(34, 197, 94, 0.15);
            --accent: #3b82f6;
            --border: #27272a;
            --glass: rgba(10, 10, 10, 0.8);
        }

        [data-theme="light"] {
            --bg: #ffffff;
            --surface: #f4f4f5;
            --text: #09090b;
            --text-dim: #71717a;
            --primary: #16a34a;
            --primary-glow: rgba(22, 163, 74, 0.1);
            --accent: #2563eb;
            --border: #e4e4e7;
            --glass: rgba(255, 255, 255, 0.8);
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            transition: background 0.5s ease;
            overflow-x: hidden;
        }

        /* Responsive Navbar */
        nav {
            position: fixed; top: 0; width: 100%;
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 5%;
            background: var(--glass);
            backdrop-filter: blur(12px);
            z-index: 1000;
            border-bottom: 1px solid var(--border);
        }

        .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 8px; }
        
        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text); font-weight: 500; font-size: 0.9rem; opacity: 0.8; transition: 0.3s; }
        .nav-links a:hover { opacity: 1; color: var(--primary); }

        /* Theme Toggle */
        #theme-toggle {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 6px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        /* Hero Section */
        .hero {
            padding: 160px 5% 100px;
            text-align: center;
            background: radial-gradient(circle at 50% -20%, var(--primary-glow), transparent 50%);
        }

        .hero h1 { 
            font-size: clamp(2.5rem, 8vw, 5rem); 
            font-weight: 800; 
            letter-spacing: -3px; 
            line-height: 1;
            margin-bottom: 20px;
        }

        .hero p { 
            max-width: 650px; margin: 0 auto 40px; 
            font-size: 1.2rem; color: var(--text-dim);
            line-height: 1.6;
        }

        .cta-group { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .btn { padding: 12px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.3s; text-decoration: none; border: none; }
        .btn-primary { background: var(--primary); color: white; box-shadow: 0 10px 20px -5px var(--primary-glow); }
        .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
        .btn:hover { transform: translateY(-2px); filter: brightness(1.1); }

        /* Floating Stats Section */
        .stats-section {
            display: flex; justify-content: center; gap: 40px; flex-wrap: wrap;
            padding: 40px 5%;
        }
        .stat-item { text-align: center; }
        .stat-item h2 { font-size: 2.5rem; color: var(--text); }
        .stat-item p { color: var(--primary); font-weight: 600; font-size: 0.9rem; text-transform: uppercase; }

        /* Terminal Window */
        .terminal-container { padding: 0 5%; margin-bottom: 100px; }
        .terminal {
            max-width: 900px; margin: 0 auto;
            background: #000; border-radius: 12px;
            border: 1px solid var(--border); overflow: hidden;
            box-shadow: 0 50px 100px -20px rgba(0,0,0,0.5);
        }
        .term-head { background: #1a1a1a; padding: 12px; display: flex; gap: 8px; border-bottom: 1px solid #333; }
        .dot { width: 12px; height: 12px; border-radius: 50%; }
        .term-body { padding: 25px; font-family: 'Fira Code', monospace; color: #a1a1aa; font-size: 14px; }

        /* Features Section */
        .section { padding: 100px 5%; }
        .section-header { text-align: center; margin-bottom: 60px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .card { 
            background: var(--surface); padding: 40px; border-radius: 20px; 
            border: 1px solid var(--border); transition: 0.3s;
        }
        .card:hover { border-color: var(--primary); background: var(--bg); }
        .card h3 { margin-bottom: 15px; font-size: 1.4rem; }
        .card p { color: var(--text-dim); }

        /* Language Slider */
        .slider-container { background: var(--surface); padding: 30px 0; overflow: hidden; white-space: nowrap; border-top: 1px solid var(--border); }
        .slider { display: inline-block; animation: slide 20s linear infinite; }
        .slider span { font-size: 1.5rem; font-weight: 800; margin: 0 40px; color: var(--text-dim); opacity: 0.4; }
        @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

        /* Testimonials */
        .testimonials { background: var(--bg); }
        .test-card { font-style: italic; font-size: 1.1rem; border-left: 4px solid var(--primary); padding-left: 20px; }

        /* Footer */
        footer { 
            padding: 80px 5% 40px; background: var(--surface); border-top: 1px solid var(--border);
        }
        .footer-grid { 
            display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; margin-bottom: 60px;
        }
        .footer-col h4 { margin-bottom: 20px; font-weight: 700; }
        .footer-col a { display: block; text-decoration: none; color: var(--text-dim); margin-bottom: 10px; font-size: 0.9rem; }
        .copyright { text-align: center; color: var(--text-dim); font-size: 0.8rem; padding-top: 40px; border-top: 1px solid var(--border); }

        /* Mobile Menu */
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .hero h1 { font-size: 3rem; }
            .section { padding: 60px 5%; }
        }
    </style>
</head>
