<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeBot Pro | AI Assistant</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        :root {
            --primary: #22c55e;
            --bg-dark: #020617;
            --sidebar-bg: rgba(15, 23, 42, 0.95);
            --border: rgba(255, 255, 255, 0.1);
            --sidebar-width: 280px;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            height: 100vh;
            background: var(--bg-dark);
            background-image: radial-gradient(circle at top right, rgba(34, 197, 94, 0.05), transparent);
            color: #fff;
            display: flex;
            overflow: hidden;
        }

        /* --- SIDEBAR DRAWER --- */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            backdrop-filter: blur(20px);
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            border-right: 1px solid var(--border);
            position: fixed;
            height: 100%;
            left: calc(-1 * var(--sidebar-width)); /* Initially hidden */
            transition: var(--transition);
            z-index: 1000;
        }

        .sidebar.active {
            left: 0;
            box-shadow: 25px 0 50px rgba(0,0,0,0.6);
        }

        .sidebar h2 {
            color: var(--primary);
            font-size: 24px;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar button {
            padding: 14px;
            border: 1px solid var(--primary);
            border-radius: 12px;
            background: rgba(34, 197, 94, 0.1);
            color: var(--primary);
            cursor: pointer;
            font-weight: 700;
            font-size: 15px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .sidebar button:hover {
            background: var(--primary);
            color: #000;
            transform: translateY(-2px);
        }

        .sidebar a {
            margin-top: auto;
            text-decoration: none;
            color: #ff4d4d;
            text-align: center;
            padding: 12px;
            border-radius: 10px;
            background: rgba(255, 77, 77, 0.1);
            font-weight: bold;
            transition: 0.3s;
        }

        .sidebar a:hover { background: #ff4d4d; color: #fff; }

        /* --- OVERLAY --- */
        .overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
            z-index: 999;
        }

        /* --- MAIN CHAT AREA --- */
        .chat-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            width: 100%;
            transition: var(--transition);
        }

        .chat-navbar {
            height: 70px;
            display: flex;
            align-items: center;
            padding: 0 25px;
            background: rgba(2, 6, 23, 0.8);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(10px);
        }

        .menu-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: white;
            padding: 10px;
            border-radius: 10px;
            cursor: pointer;
            margin-right: 20px;
            transition: 0.3s;
        }

        .menu-btn:hover { background: var(--primary); color: #000; }

        .chat-navbar h1 {
            font-size: 20px;
            color: var(--primary);
            font-weight: 700;
        }

        /* --- MESSAGES --- */
        .messages {
            flex: 1;
            padding: 30px 15%;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            scroll-behavior: smooth;
        }

        .msg {
            max-width: 75%;
            padding: 15px 20px;
            border-radius: 18px;
            font-size: 15px;
            line-height: 1.6;
            animation: slideIn 0.4s ease forwards;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user { align-self: flex-end; background: #2563eb; border-bottom-right-radius: 2px; }
        .bot { align-self: flex-start; background: #1e293b; border: 1px solid var(--border); border-bottom-left-radius: 2px; }

        /* --- INPUT AREA --- */
        .input-area {
            padding: 25px 15%;
            background: linear-gradient(transparent, var(--bg-dark));
        }

        .input-box {
            display: flex;
            background: #1e293b;
            padding: 10px 18px;
            border-radius: 16px;
            border: 1px solid var(--border);
            transition: 0.3s;
        }

        .input-box:focus-within { border-color: var(--primary); box-shadow: 0 0 15px rgba(34, 197, 94, 0.2); }

        .input-box input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 16px;
        }

        .input-box button {
            background: var(--primary);
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 10px;
            cursor: pointer;
            color: #000;
            display: grid;
            place-items: center;
            transition: 0.3s;
        }

        /* --- TOAST POPUP --- */
        .toast {
            position: fixed;
            top: 25px;
            right: -300px;
            background: var(--primary);
            color: #000;
            padding: 12px 25px;
            border-radius: 12px;
            font-weight: 700;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            z-index: 2000;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .toast.show { right: 25px; }

        /* Responsive */
        @media (max-width: 850px) {
            .messages, .input-area { padding-left: 20px; padding-right: 20px; }
        }
    </style>
</head>
<body>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

    <div class="toast" id="toast">
        <i data-lucide="sparkles"></i> New Chat Started!
    </div>

    <div class="sidebar" id="sidebar">
        <h2><i data-lucide="bot"></i> CodeBot</h2>
        <button onclick="handleNewChat()">
            <i data-lucide="plus"></i> New Chat
        </button>
        <a href="/">Logout</a>
    </div>

    <div class="chat-container">
        <nav class="chat-navbar">
            <button class="menu-btn" onclick="toggleSidebar()">
                <i data-lucide="menu"></i>
            </button>
            <h1>ChatBot Dashboard</h1>
        </nav>

        <div id="messages" class="messages">
            <div class="msg bot">Hello! I'm your professional coding assistant. How can I help?</div>
        </div>

        <div class="input-area">
            <div class="input-box">
                <input id="msg" placeholder="Type your coding question..."
                       onkeydown="if(event.key==='Enter') sendMessage()">
                <button onclick="sendMessage()">
                    <i data-lucide="send-horizonal"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // 1. Sidebar Toggle Function
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            sidebar.classList.toggle('active');
            overlay.style.display = sidebar.classList.contains('active') ? 'block' : 'none';
        }

        // 2. New Chat with Popup Functionalitiy
        function handleNewChat() {
            // Call your actual logic from chat.js
            if(typeof newChat === 'function') {
                newChat(); 
            } else {
                // Fallback reset if chat.js is not loaded
                document.getElementById('messages').innerHTML = '<div class="msg bot">New session started.</div>';
            }

            // Show Toast Animation
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);

            // Close sidebar after clicking
            toggleSidebar();
        }

        // 3. Send Message Placeholder 
        // Note: This will work with your existing sendMessage in chat.js
        // If you haven't defined it there, this ensures basic UI works.
        const originalSendMessage = window.sendMessage; 
        window.sendMessage = function() {
            const input = document.getElementById('msg');
            const container = document.getElementById('messages');
            
            if (input.value.trim() !== "") {
                const userMsg = document.createElement('div');
                userMsg.className = 'msg user';
                userMsg.textContent = input.value;
                container.appendChild(userMsg);
                container.scrollTop = container.scrollHeight;
                
                // Trigger the actual bot logic if it exists
                if(typeof originalSendMessage === 'function') originalSendMessage();
                
                input.value = "";
            }
        };
    </script>
    <script src="/js/chat.js"></script>
</body>
</html>