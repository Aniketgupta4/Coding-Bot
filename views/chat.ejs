<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>CodeBot Pro | Dashboard</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        const savedTheme = localStorage.getItem('site-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    
    <style>
        :root {
            --primary: #22c55e;
            --bg-dark: #020617;
            --sidebar-bg: #0f172a;
            --border: rgba(255, 255, 255, 0.1);
            --sidebar-width: 280px;
            --text-main: #ffffff;
            --msg-bot: #1e293b;
            --msg-user: #2563eb;
            --toast-bg: #10b981;
            --scrollbar-thumb: rgba(255, 255, 255, 0.2);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="light"] {
            --bg-dark: #f8fafc;
            --sidebar-bg: #ffffff;
            --border: rgba(0, 0, 0, 0.1);
            --text-main: #0f172a;
            --msg-bot: #e2e8f0;
            --msg-user: #3b82f6;
            --scrollbar-thumb: rgba(0, 0, 0, 0.2);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease; }

        /* --- THE ULTIMATE MOBILE FIX --- */
        body, html {
            background: var(--bg-dark);
            color: var(--text-main);
            /* Grid layout ensures strict height bounds without scrolling the body */
            display: grid;
            grid-template-columns: var(--sidebar-width) 1fr;
            width: 100vw;
            height: 100dvh; /* Dynamic Viewport for mobile URL bars */
            overflow: hidden;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
        }

        /* --- CUSTOM SLEEK SCROLLBAR --- */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--primary); }

        /* --- TOAST NOTIFICATION --- */
        #toast {
            visibility: hidden; min-width: 280px; background-color: var(--toast-bg); color: #fff;
            text-align: center; border-radius: 10px; padding: 16px 20px; position: fixed; z-index: 5000;
            left: 50%; transform: translateX(-50%); bottom: 30px; font-size: 14px; font-weight: 600;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; gap: 12px;
        }
        #toast.show { visibility: visible; animation: fadein 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), fadeout 0.4s 2.5s forwards; }

        @keyframes fadein { from {bottom: 0; opacity: 0; transform: translate(-50%, 20px);} to {bottom: 30px; opacity: 1; transform: translate(-50%, 0);} }
        @keyframes fadeout { from {bottom: 30px; opacity: 1; transform: translate(-50%, 0);} to {bottom: 0; opacity: 0; transform: translate(-50%, -20px);} }

        /* --- SIDEBAR --- */
        .sidebar {
            background: var(--sidebar-bg); border-right: 1px solid var(--border);
            display: flex; flex-direction: column; padding: 20px; 
            height: 100dvh; transition: transform var(--transition);
            z-index: 2000; position: relative;
        }

        .sidebar h2 { color: var(--primary); font-size: 22px; font-weight: 800; margin-bottom: 25px; display: flex; align-items: center; gap: 10px; flex-shrink: 0; }

        .new-chat-btn {
            width: 100%; padding: 12px; background: rgba(34, 197, 94, 0.1); border: 1px solid var(--primary); color: var(--primary);
            border-radius: 10px; cursor: pointer; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.3s; margin-bottom: 20px; flex-shrink: 0;
        }
        .new-chat-btn:hover { background: var(--primary); color: #000; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(34,197,94,0.2); }

        .history-container { flex: 1; overflow-y: auto; margin-bottom: 20px; display: flex; flex-direction: column; gap: 5px; padding-right: 5px; }
        .history-label { font-size: 11px; text-transform: uppercase; color: #64748b; letter-spacing: 1px; margin-bottom: 12px; display: block; flex-shrink: 0; }

        /* --- INLINE EDIT UI --- */
        .history-item-wrapper { display: flex; align-items: center; padding: 10px 12px; border-radius: 10px; background: rgba(128, 128, 128, 0.05); cursor: pointer; gap: 10px; border: 1px solid transparent; position: relative; transition: 0.2s; flex-shrink: 0;}
        .history-item-wrapper:hover { background: rgba(34, 197, 94, 0.05); border-color: var(--primary); }
        .chat-title-text { flex: 1; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        
        .edit-input { flex: 1; background: var(--bg-dark); border: 1px solid var(--primary); color: var(--text-main); font-size: 13px; padding: 6px 8px; border-radius: 6px; outline: none; display: none; width: 100%; }

        .history-actions { display: flex; gap: 8px; opacity: 0; transition: 0.2s; }
        .history-item-wrapper:hover .history-actions { opacity: 1; }
        .history-actions i { width: 16px; color: #64748b; cursor: pointer; transition: color 0.2s, transform 0.2s; }
        .history-actions i:hover { color: var(--primary); transform: scale(1.1); }
        .history-actions i.trash-icon:hover { color: #ef4444; }

        .logout-btn { padding: 12px; text-decoration: none; color: #ef4444; background: rgba(239, 68, 68, 0.1); border-radius: 8px; text-align: center; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 8px; transition: 0.2s; flex-shrink: 0; margin-top: auto;}
        .logout-btn:hover { background: #ef4444; color: #fff; }

        /* --- CHAT MAIN AREA --- */
        .chat-main { 
            display: flex; flex-direction: column; 
            height: 100dvh; min-width: 0; 
            position: relative;
        }
        
        .navbar { height: 65px; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; background: var(--bg-dark); border-bottom: 1px solid var(--border); flex-shrink: 0; }
        .nav-left { display: flex; align-items: center; gap: 15px; }

        .menu-toggle { display: none; background: none; border: 1px solid var(--border); color: var(--text-main); padding: 8px; border-radius: 8px; cursor: pointer; transition: 0.2s; }
        .menu-toggle:hover { background: var(--sidebar-bg); }

        .theme-toggle-btn { background: none; border: 1px solid var(--border); color: var(--text-main); padding: 8px 12px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; transition: 0.2s; }
        .theme-toggle-btn:hover { background: var(--sidebar-bg); }

        /* The flex: 1 and overflow-y: auto makes ONLY the messages area scrollable */
        .messages { flex: 1; padding: 20px 10%; overflow-y: auto; display: flex; flex-direction: column; gap: 20px; scroll-behavior: smooth; }
        
        .msg { max-width: 85%; padding: 14px 18px; border-radius: 18px; font-size: 15px; line-height: 1.6; word-wrap: break-word; animation: fadeIn 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        .user { align-self: flex-end; background: var(--msg-user); color: #fff; border-bottom-right-radius: 4px; }
        .bot { align-self: flex-start; background: var(--msg-bot); color: var(--text-main); border: 1px solid var(--border); border-bottom-left-radius: 4px; }

        /* --- INPUT AREA MOBILE FIX --- */
        /* Flex-shrink: 0 ensures it never gets squished */
        .input-wrapper { 
            padding: 15px 10%; 
            background: var(--bg-dark); 
            border-top: 1px solid var(--border); 
            flex-shrink: 0; 
            width: 100%;
        }

        .input-box { display: flex; background: var(--sidebar-bg); border: 1px solid var(--border); border-radius: 16px; padding: 8px 15px; align-items: center; gap: 12px; transition: 0.3s; width: 100%;}
        .input-box:focus-within { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15); }
        
        .input-box input { 
            flex: 1; background: transparent; border: none; outline: none; color: var(--text-main); 
            /* 16px font size prevents iOS from zooming in when typing */
            font-size: 16px; 
            padding: 10px 0; 
        }
        
        .send-btn { background: var(--primary); border: none; width: 42px; height: 42px; border-radius: 12px; color: #000; cursor: pointer; display: grid; place-items: center; transition: 0.2s; flex-shrink: 0; }
        .send-btn:hover { transform: scale(1.05); }

        .shared-footer { padding: 10px; text-align: center; font-size: 11px; color: #64748b; border-top: 1px solid var(--border); background: var(--bg-dark); flex-shrink: 0; padding-bottom: calc(10px + env(safe-area-inset-bottom)); }

        /* --- MOBILE RESPONSIVE OVERRIDES --- */
        @media (max-width: 768px) {
            body { display: block; } /* Revert grid on mobile */
            
            .sidebar { 
                position: fixed; 
                left: 0; top: 0; 
                width: 280px; 
                transform: translateX(-100%); /* Hidden by default */
                box-shadow: 10px 0 30px rgba(0,0,0,0.5); 
            }
            .sidebar.active { transform: translateX(0); }
            
            .nav-left .menu-toggle { display: block; }
            
            .messages { padding: 20px 5%; }
            .input-wrapper { padding: 10px 5%; padding-bottom: calc(10px + env(safe-area-inset-bottom)); }
            .msg { max-width: 95%; font-size: 14px; }
            .history-actions { opacity: 1; }
        }

        .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(3px); z-index: 1500; }
        .overlay.active { display: block; }
        
        /* --- BEAUTIFUL DELETE MODAL --- */
        .modal { display: none; position: fixed; z-index: 4000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px); align-items: center; justify-content: center; }
        .modal-content { background-color: var(--sidebar-bg); padding: 30px; border-radius: 16px; border: 1px solid var(--border); width: 90%; max-width: 320px; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.3); animation: modalPop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes modalPop { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-icon { color: #ef4444; width: 48px; height: 48px; margin-bottom: 15px; }
        .modal-buttons { margin-top: 25px; display: flex; gap: 12px; justify-content: center; }
        .btn-cancel { flex: 1; padding: 12px; border-radius: 8px; border: 1px solid var(--border); background: transparent; color: var(--text-main); font-weight: 600; cursor: pointer; transition: 0.2s; }
        .btn-cancel:hover { background: rgba(128,128,128,0.1); }
        .btn-confirm { flex: 1; padding: 12px; border-radius: 8px; border: none; background: #ef4444; color: white; font-weight: 600; cursor: pointer; transition: 0.2s; }
        .btn-confirm:hover { background: #dc2626; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(239,68,68,0.3); }
    </style>
</head>
<body data-theme="dark">

    <div class="overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    
    <div id="toast"><i id="toast-icon"></i> <span id="toast-msg">Notification</span></div>

    <div id="deleteModal" class="modal">
      <div class="modal-content">
        <i data-lucide="alert-triangle" class="modal-icon"></i>
        <h3 style="margin-bottom: 10px; font-size: 20px;">Delete Chat?</h3>
        <p style="font-size: 14px; color: #64748b;">This action cannot be undone. Are you sure you want to permanently delete this conversation?</p>
        <div class="modal-buttons">
          <button class="btn-cancel" onclick="closeDeleteModal()">Cancel</button>
          <button class="btn-confirm" id="confirmDeleteBtn">Delete</button>
        </div>
      </div>
    </div>

    <aside class="sidebar" id="sidebar">
        <h2><i data-lucide="zap"></i> CodeBot</h2>
        
        <button class="new-chat-btn" onclick="startNewChatHandler()">
            <i data-lucide="plus"></i> New Chat
        </button>

        <div class="history-container">
            <span class="history-label">My History</span>
            <% history.forEach(chat => { %>
                <div class="history-item-wrapper" id="item-<%= chat._id %>">
                    <span class="chat-title-text" onclick="loadChat('<%= chat._id %>')"><%= chat.title %></span>
                    <input type="text" class="edit-input" value="<%= chat.title %>" 
                           onblur="saveRename('<%= chat._id %>', this)" 
                           onkeydown="if(event.key==='Enter') this.blur()">
                    
                    <div class="history-actions">
                        <i data-lucide="edit-3" onclick="enableEdit('<%= chat._id %>')"></i>
                        <i data-lucide="trash-2" class="trash-icon" onclick="openDeleteModal('<%= chat._id %>')"></i>
                    </div>
                </div>
            <% }) %>
        </div>

        <a href="/logout" class="logout-btn">
            <i data-lucide="log-out"></i> Sign Out
        </a>
    </aside>

    <main class="chat-main">
        <nav class="navbar">
            <div class="nav-left">
                <button class="menu-toggle" onclick="toggleSidebar()">
                    <i data-lucide="menu"></i>
                </button>
                <h1 id="pageTitle" style="font-size: 18px; font-weight: 700;">Developer Studio</h1>
            </div>
            
            <button class="theme-toggle-btn" onclick="toggleTheme()" id="theme-btn">
                <i data-lucide="sun" id="themeIcon"></i> <span id="themeText">Light Mode</span>
            </button>
        </nav>

        <div id="messages" class="messages">
            <div class="msg bot">Select a previous chat or start a new one to begin.</div>
        </div>

        <div class="input-wrapper">
            <div class="input-box">
                <input type="text" id="msg" placeholder="Ask a coding question..." 
                       onkeydown="if(event.key === 'Enter') sendMessage()">
                <button class="send-btn" onclick="sendMessage()">
                    <i data-lucide="send-horizonal"></i>
                </button>
            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();

        // --- Centralized Theme logic ---
        function applyTheme(theme) {
            document.body.setAttribute('data-theme', theme);
            localStorage.setItem('site-theme', theme);
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            
            if(theme === 'dark') {
                icon.setAttribute('data-lucide', 'sun');
                text.innerText = "Light Mode";
            } else {
                icon.setAttribute('data-lucide', 'moon');
                text.innerText = "Dark Mode";
            }
            lucide.createIcons();
        }

        applyTheme(localStorage.getItem('site-theme') || 'dark');

        function toggleTheme() {
            const current = document.body.getAttribute('data-theme');
            applyTheme(current === 'dark' ? 'light' : 'dark');
        }

        // --- Responsive Toggle ---
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        // --- Premium Toast Notification ---
        function showToast(message, type = 'success') {
            const toast = document.getElementById("toast");
            const msg = document.getElementById("toast-msg");
            const icon = document.getElementById("toast-icon");
            
            msg.innerText = message;
            
            if(type === 'success') {
                toast.style.backgroundColor = 'var(--toast-bg)';
                icon.setAttribute('data-lucide', 'check-circle');
            } else if (type === 'error') {
                toast.style.backgroundColor = '#ef4444';
                icon.setAttribute('data-lucide', 'alert-circle');
            } else {
                toast.style.backgroundColor = 'var(--primary)';
                icon.setAttribute('data-lucide', 'info');
            }
            lucide.createIcons();
            
            // Re-trigger animation
            toast.classList.remove("show");
            void toast.offsetWidth; // trigger reflow
            toast.classList.add("show");
        }

        async function startNewChatHandler() {
             if(typeof startNewChat === 'function'){
                 await startNewChat();
                 showToast("New chat started successfully!", "success");
                 if(window.innerWidth <= 768) toggleSidebar();
             }
        }

        // --- Inline Rename Logic ---
        function enableEdit(id) {
            const wrapper = document.getElementById(`item-${id}`);
            const textSpan = wrapper.querySelector('.chat-title-text');
            const inputField = wrapper.querySelector('.edit-input');
            
            textSpan.style.display = 'none';
            inputField.style.display = 'block';
            inputField.focus();
            inputField.setSelectionRange(inputField.value.length, inputField.value.length);
        }

        async function saveRename(id, inputElement) {
            const newTitle = inputElement.value.trim();
            const wrapper = document.getElementById(`item-${id}`);
            const textSpan = wrapper.querySelector('.chat-title-text');
            
            if (newTitle && newTitle !== textSpan.innerText) {
                try {
                    const res = await fetch(`/chat/rename/${id}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ title: newTitle })
                    });
                    if(res.ok) {
                        textSpan.innerText = newTitle;
                        showToast("Chat renamed successfully", "success");
                    }
                } catch(e) {
                    showToast("Failed to rename chat", "error");
                }
            }
            textSpan.style.display = 'block';
            inputElement.style.display = 'none';
        }

        // --- Premium Delete Modal Logic ---
        let chatToDelete = null;
        function openDeleteModal(id) {
            chatToDelete = id;
            document.getElementById('deleteModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            chatToDelete = null;
            document.getElementById('deleteModal').style.display = 'none';
        }

        document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
            if(chatToDelete) {
                try {
                    const res = await fetch(`/chat/${chatToDelete}`, { method: 'DELETE' });
                    if(res.ok) {
                        const item = document.getElementById(`item-${chatToDelete}`);
                        item.style.opacity = '0';
                        setTimeout(() => item.remove(), 300); // smooth remove
                        
                        showToast("Chat deleted permanently", "success");
                        closeDeleteModal();
                        
                        if(typeof currentChatId !== 'undefined' && currentChatId === chatToDelete) {
                           document.getElementById("messages").innerHTML = '<div class="msg bot">Select a previous chat or start a new one to begin.</div>';
                           currentChatId = null;
                        }
                    }
                } catch(e) {
                     showToast("Error deleting chat", "error");
                }
            }
        });

    </script>
    <script src="/js/chat.js"></script>
</body>
</html>