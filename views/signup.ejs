<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup | CodeBot AI</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Same Matte Dark Theme as Front Page */
            --bg: #0a0a0a;
            --surface: #141414;
            --text: #ffffff;
            --text-dim: #a1a1aa;
            --primary: #22c55e;
            --primary-glow: rgba(34, 197, 94, 0.15);
            --border: #27272a;
            --glass: rgba(10, 10, 10, 0.8);
        }

        [data-theme="light"] {
            --bg: #ffffff;
            --surface: #f4f4f5;
            --text: #09090b;
            --text-dim: #71717a;
            --primary: #16a34a;
            --primary-glow: rgba(22, 163, 74, 0.1);
            --border: #e4e4e7;
            --glass: rgba(255, 255, 255, 0.8);
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            transition: background 0.5s ease;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar */
        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 1rem 8%;
            background: var(--glass);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            z-index: 100;
        }

        .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 8px; }
        
        #theme-toggle {
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 6px 14px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
        }

        /* Signup Content Area */
        .main-content {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
            background: radial-gradient(circle at center, var(--primary-glow), transparent 75%);
        }

        .signup-card {
            background: var(--surface);
            width: 100%;
            max-width: 420px;
            padding: 40px;
            border-radius: 24px;
            border: 1px solid var(--border);
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            animation: slideUp 0.6s ease;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 { font-size: 2.2rem; margin-bottom: 8px; text-align: center; letter-spacing: -1px; }
        .subtitle { color: var(--text-dim); text-align: center; margin-bottom: 30px; font-size: 0.95rem; }

        form input {
            width: 100%;
            padding: 14px 18px;
            margin-bottom: 18px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--bg);
            color: var(--text);
            font-size: 1rem;
            outline: none;
            transition: 0.3s;
        }

        form input:focus { 
            border-color: var(--primary); 
            box-shadow: 0 0 0 3px var(--primary-glow); 
        }

        .btn-signup {
            width: 100%;
            padding: 14px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            box-shadow: 0 10px 20px -5px var(--primary-glow);
        }

        .btn-signup:hover { 
            transform: translateY(-2px); 
            filter: brightness(1.1); 
            box-shadow: 0 15px 25px -5px var(--primary-glow);
        }

        .switch-text { text-align: center; margin-top: 25px; color: var(--text-dim); font-size: 0.9rem; }
        .switch-text a { color: var(--primary); text-decoration: none; font-weight: 600; }
        .switch-text a:hover { text-decoration: underline; }

        /* Professional Multi-Column Footer (Same as Front Page) */
        footer { 
            padding: 80px 8% 40px; 
            background: var(--surface); 
            border-top: 1px solid var(--border);
            margin-top: auto;
        }

        .footer-grid { 
            display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 50px;
        }

        .footer-logo-col p { 
            color: var(--text-dim); 
            font-size: 0.95rem; 
            margin-top: 15px; 
            max-width: 250px;
            line-height: 1.6;
        }

        .footer-col h4 { margin-bottom: 22px; font-weight: 700; font-size: 1rem; color: var(--text); }
        .footer-col a { display: block; text-decoration: none; color: var(--text-dim); margin-bottom: 12px; font-size: 0.9rem; transition: 0.3s; }
        .footer-col a:hover { color: var(--primary); transform: translateX(5px); }

        .copyright { 
            text-align: center; color: var(--text-dim); font-size: 0.85rem; 
            padding-top: 30px; border-top: 1px solid var(--border); 
        }

        /* RESPONSIVE FIXES */
        @media (max-width: 768px) {
            .footer-grid { grid-template-columns: 1fr 1fr; }
            .footer-logo-col { grid-column: span 2; }
            nav { padding: 1rem 5%; }
        }

        @media (max-width: 480px) {
            .footer-grid { grid-template-columns: 1fr; }
            .footer-logo-col { grid-column: span 1; }
            .signup-card { padding: 30px 20px; border: none; background: transparent; box-shadow: none; }
        }
    </style>
</head>
<body data-theme="dark">

    <nav>
        <a href="/" class="logo"><span>⚡</span> CodeBot</a>
        <button id="theme-toggle" onclick="toggleTheme()">☀️ Light Mode</button>
    </nav>

    <div class="main-content">
        <div class="signup-card">
            <h2>Join CodeBot</h2>
            <p class="subtitle">Start building your next big thing with AI.</p>
            
            <form method="POST" action="/signup">
                <input name="email" type="email" placeholder="Email Address" required>
                <input name="password" type="password" placeholder="Create Password" required>
                <button type="submit" class="btn-signup">Create Account</button>
            </form>

            <p class="switch-text">Already have an account? <a href="/login">Log in</a></p>
        </div>
    </div>

    <footer>
        <div class="footer-grid">
            <div class="footer-col footer-logo-col">
                <div class="logo"><span>⚡</span> CodeBot</div>
                <p>The only AI partner you'll ever need for building production-grade software.</p>
            </div>
            <div class="footer-col">
                <h4>Product</h4>
                <a href="#">Features</a>
                <a href="#">Security</a>
                <a href="#">CLI Tool</a>
            </div>
            <div class="footer-col">
                <h4>Company</h4>
                <a href="#">About Us</a>
                <a href="#">Blog</a>
                <a href="#">Careers</a>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <a href="https://www.linkedin.com/in/gupta-aniket5/">LinkedIn</a>
            </div>
        </div>
        <div class="copyright">
            &copy; 2026 CodeBot AI Inc. Made for developers by developers.
        </div>
    </footer>

    <script>
        // Sync Theme Functionality
        function toggleTheme() {
            const body = document.body;
            const btn = document.getElementById('theme-toggle');
            if (body.getAttribute('data-theme') === 'dark') {
                body.setAttribute('data-theme', 'light');
                btn.innerHTML = "🌙 Dark Mode";
            } else {
                body.setAttribute('data-theme', 'dark');
                btn.innerHTML = "☀️ Light Mode";
            }
        }
    </script>
</body>
</html>