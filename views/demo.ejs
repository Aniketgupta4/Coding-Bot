<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Chatbot Demo</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        /* Essential for mobile height fixes */
        html, body {
            height: 100%;
            height: -webkit-fill-available;
            overflow: hidden;
        }

        body {
            display: flex;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1e1e2f;
            color: #fff;
        }

        /* --- SIDEBAR (Mobile Drawer) --- */
        .sidebar {
            width: 240px;
            background: linear-gradient(180deg, #111827, #020617);
            padding: 20px;
            display: flex;
            flex-direction: column;
            box-shadow: 4px 0 12px rgba(0,0,0,.4);
            transition: transform 0.3s ease;
            z-index: 1001;
        }

        .sidebar h2 {
            margin-bottom: 20px;
            color: #22c55e;
            text-align: center;
        }

        .sidebar p {
            font-size: 14px;
            color: #9ca3af;
            line-height: 1.5;
            text-align: center;
        }

        /* --- CHAT AREA --- */
        .chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #0f172a;
            position: relative;
            height: 100%;
        }

        /* Mobile Navbar */
        .mobile-header {
            display: none;
            background: #111827;
            padding: 10px 15px;
            align-items: center;
            border-bottom: 1px solid #334155;
        }

        .menu-toggle {
            background: none;
            border: 1px solid #334155;
            color: white;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            margin-right: 15px;
        }

        .messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
            -webkit-overflow-scrolling: touch;
        }

        .msg {
            max-width: 80%;
            padding: 12px 16px;
            border-radius: 16px;
            font-size: 15px;
            line-height: 1.5;
            box-shadow: 0 2px 6px rgba(0,0,0,.4);
            word-wrap: break-word;
        }

        .user {
            align-self: flex-end;
            background: #2563eb;
            border-bottom-right-radius: 0;
        }

        .bot {
            align-self: flex-start;
            background: #334155;
            border-bottom-left-radius: 0;
        }

        /* --- INPUT AREA --- */
        .input-area {
            display: flex;
            padding: 15px;
            background: #020617;
            border-top: 1px solid #334155;
            flex-shrink: 0; /* Prevents input from squashing */
        }

        .input-area input {
            flex: 1;
            padding: 12px 16px;
            border-radius: 20px;
            border: none;
            outline: none;
            background: #1f2937;
            color: #fff;
            font-size: 16px; /* Prevents iOS auto-zoom */
        }

        .input-area button {
            margin-left: 10px;
            padding: 0 20px;
            border-radius: 20px;
            border: none;
            cursor: pointer;
            font-weight: bold;
            background: #22c55e;
            color: #000;
        }

        /* --- POPUP --- */
        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.85);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 20px;
        }

        .popup {
            background: #1f2937;
            padding: 30px;
            width: 100%;
            max-width: 360px;
            border-radius: 16px;
            text-align: center;
        }

        .popup a {
            display: block;
            margin-top: 10px;
            padding: 12px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: bold;
        }

        .login-btn { background: #2563eb; color: #fff; }
        .signup-btn { background: #22c55e; color: #000; }

        /* --- MOBILE MEDIA QUERIES --- */
        @media (max-width: 768px) {
            .sidebar {
                position: fixed;
                left: 0;
                top: 0;
                bottom: 0;
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .mobile-header {
                display: flex;
            }
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 1000;
            }
            .sidebar-overlay.show { display: block; }
            .msg { max-width: 90%; }
        }
    </style>
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleMenu()"></div>

    <div class="sidebar" id="sidebar">
        <h2>CodeBot</h2>
        <p>Demo Mode<br>Login required for full access</p>
    </div>

    <div class="chat">
        <div class="mobile-header">
            <button class="menu-toggle" onclick="toggleMenu()">☰</button>
            <strong style="color: #22c55e;">CodeBot Demo</strong>
        </div>

        <div id="messages" class="messages"></div>

        <div class="input-area">
            <input id="msg" placeholder="Ask something..." onkeydown="if(event.key==='Enter') sendMessage()">
            <button onclick="sendMessage()">Send</button>
        </div>
    </div>

    <div id="overlay" class="overlay">
        <div class="popup">
            <h3>Login Required</h3>
            <p>Demo time is over.<br>Please login to continue.</p>
            <a href="/login" class="login-btn">Login</a>
            <a href="/signup" class="signup-btn">Create Account</a>
        </div>
    </div>

    <script>
        // Responsive Menu Function
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        const messages = document.getElementById("messages");
        const input = document.getElementById("msg");

        const demoReplies = [
            "Thinking 🤖",
            "Answering 🚀",
            ".... 😉",
            "Wait for Response."
        ];

        function addMsg(text, cls) {
            const div = document.createElement("div");
            div.className = `msg ${cls}`;
            div.innerText = text;
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        function sendMessage() {
            const text = input.value.trim();
            if (!text) return;

            addMsg(text, "user");
            input.value = "";

            setTimeout(() => {
                const reply = demoReplies[Math.floor(Math.random() * demoReplies.length)];
                addMsg(reply, "bot");
            }, 600);
        }

        /* DEMO TIMER */
        setTimeout(() => {
            document.getElementById("overlay").style.display = "flex";
            input.disabled = true;
        }, 4000); 
    </script>

</body>
</html>